                  <![CDATA[import almath
class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)

    def onLoad(self):
        #put initialization code here
        pass

    def onUnload(self):
        #put clean-up code here
        pass

    def onInput_onStart(self):
        motionProxy = ALProxy("ALMotion")
        namesLArm = ["LShoulderPitch", "LShoulderRoll", "LElbowYaw", "LElbowRoll", "LWristYaw"]
        anglesLArm = [[1.3*almath.TO_RAD], [22*almath.TO_RAD], [1.7*almath.TO_RAD], [-32.1*almath.TO_RAD], [9.4*almath.TO_RAD]]
        timesLArm = [[2], [2], [2], [2], [2]]
        motionProxy.angleInterpolation(namesLArm, anglesLArm, timesLArm, True)

        namesRArm = ["RShoulderPitch", "RShoulderRoll", "RElbowYaw", "RElbowRoll", "RWristYaw"]
        anglesRArm = [[6.7*almath.TO_RAD], [-20.4*almath.TO_RAD], [21.3*almath.TO_RAD], [44.1*almath.TO_RAD], [-31.2*almath.TO_RAD]]
        timesRArm = [[2], [2], [2], [2], [2]]
        motionProxy.angleInterpolation(namesRArm, anglesRArm, timesRArm, True)

        namesLLeg = ["LHipYawPitch", "LHipRoll", "LHipPitch", "LKneePitch", "LAnklePitch", "LAnkleRoll"]
        anglesLLeg = [[-10.9*almath.TO_RAD], [-5.3*almath.TO_RAD], [-52.2*almath.TO_RAD], [65.5*almath.TO_RAD], [-3.2*almath.TO_RAD], [3.4*almath.TO_RAD]]
        timesLLeg = [[2], [2], [2], [2], [2], [2]]
        motionProxy.angleInterpolation(namesLLeg, anglesLLeg, timesLLeg, True)

        namesRLeg = ["RHipYawPitch", "RHipRoll", "RHipPitch", "RKneePitch", "RAnklePitch", "RAnkleRoll"]
        anglesRLeg = [[-10.9*almath.TO_RAD], [4.3*almath.TO_RAD], [-54.6*almath.TO_RAD], [63.4*almath.TO_RAD], [0.1*almath.TO_RAD], [-3.2*almath.TO_RAD]]
        timesRLeg = [[2], [2], [2], [2], [2], [2]]
        motionProxy.angleInterpolation(namesRLeg, anglesRLeg, timesRLeg, True)
        self.onStopped() #activate the output of the box
        pass

    def onInput_onStop(self):
        self.onUnload() #it is recommended to reuse the clean-up as the box is stopped
        self.onStopped() #activate the output of the box]]>
                </content>
              </script>

        angles = [[-18*almath.TO_RAD, 45*almath.TO_RAD], [-5*almath.TO_RAD, -5*almath.TO_RAD]]
        times = [[1, 2], [1, 2]]
        motionProxy.angleInterpolation(names, angles, times, True)
        self.onStopped() #activate the output of the box
        pass

    def onInput_onStop(self):
